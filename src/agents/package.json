{
  "name": "echo-agents",
  "version": "1.0.0",
  "description": "ECHO Agent OS — Orchestrator, Auditor, Governor agents",
  "scripts": {
    "test": "jest --testPathPattern=agents.test --forceExit --no-coverage",
    "test:run": "jest --testPathPattern=agents.test --forceExit --no-coverage",
    "test:core": "jest --testPathPattern=core.test --forceExit --no-coverage",
    "test:all": "jest --forceExit --no-coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>", "<rootDir>/../execution", "<rootDir>/../reasoning", "<rootDir>/../ledger", "<rootDir>/../security"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": { "module": "CommonJS", "moduleResolution": "node", "isolatedModules": true } }]
    }
  }
}
