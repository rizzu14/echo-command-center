{
  "name": "@echo/database",
  "version": "0.1.0",
  "private": true,
  "description": "PostgreSQL multi-tenant schema, RLS helpers, and connection pool for ECHO",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "migrate:up": "node-pg-migrate up --migrations-dir migrations --migration-file-language sql",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --migration-file-language sql",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language sql",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.9.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
